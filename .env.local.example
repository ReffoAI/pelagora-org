# ── SITE URL ──────────────────────────────────────────────────────────────────
# Used to build absolute og:image and og:url tags for social share previews.
# Set to the canonical domain for the environment (no trailing slash).
NEXT_PUBLIC_SITE_URL=https://pelagora.org

# ── SUPABASE ─────────────────────────────────────────────────────────────────
# Same Supabase project used by reffo-marketing.
# Dashboard → Settings → API
# If these are not set, the site falls back to the static mock posts in
# lib/mock-blog-posts.ts (useful for local development without a DB).
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
